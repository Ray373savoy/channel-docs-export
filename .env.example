# ── Channel Talk Document API ──────────────────────────────────────────────────
# Channel Desk → Documents → 対象スペース → Space Settings → API Keys から発行
CHANNEL_DOC_ACCESS_KEY=
CHANNEL_DOC_ACCESS_SECRET=

# ── Google OAuth（alf-data collector と同じ認証情報を流用可能）──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ────────────────────────────────────────────────────────────────────
# ローカル開発: http://localhost:3000  本番: https://your-app.vercel.app
NEXTAUTH_URL=https://your-app.vercel.app
# openssl rand -base64 32 で生成してください
NEXTAUTH_SECRET=

# ── Google Sheets ログ（取得ログの保存先）────────────────────────────────────────
# GCP のサービスアカウント JSON キーを base64 エンコードした値
# 作成方法: cat key.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=

# ログ保存先スプレッドシートID（URLの /d/XXXXXX/edit の XXXXXX 部分）
GOOGLE_SHEETS_SPREADSHEET_ID=
